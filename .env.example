# Stacks reads all app configuration (model, temperature, prompts, PDF pages,
# OneDrive backup, AI feed) from the in-app Settings, stored in the library's
# settings.json. You normally don't need any env vars.
#
# The few below are only for seeding secrets or the library location before the
# UI is used (e.g. a headless or first-run setup). Everything else is set in
# Settings → AI & models.

# API keys (optional — you can also enter these in Settings):
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
SERPAPI_KEY=your_serpapi_key

# Where the library folder lives (defaults to ~/.stacks/library). This is the
# one setting that must be an env var, since it's read before settings.json:
# STACKS_LIBRARY_DIR=~/Documents/Stacks
