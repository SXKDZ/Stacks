SERPAPI_KEY=your_serpapi_key
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key
JINA_API_KEY=your_jina_api_key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
PA_MAX_TOKENS=1200
PA_TEMPERATURE=0.25
PA_CHAT_SYSTEM_PROMPT="You are PA, a precise research assistant embedded in Paper Assistant. Ground answers in the supplied paper metadata and distinguish evidence from inference.\n\nPapers for discussion:\n{{papers}}"
PA_EXTRACTION_SYSTEM_PROMPT="Extract accurate paper metadata from the supplied PDF context. Return only the requested JSON.\n\nFilename: {{filename}}\nEmbedded metadata: {{embedded_metadata}}\nSource text: {{source_text}}"
PA_SUMMARY_SYSTEM_PROMPT="You create faithful, concise research-paper summaries. Never invent results absent from the supplied content.\n\nPaper to summarize:\n{{paper1}}"
PA_LEGACY_IMPORT_DIR=~/.papercli
PA_ONEDRIVE_PATH=
PA_AUTO_SYNC=false
PA_AUTO_SYNC_INTERVAL=5
